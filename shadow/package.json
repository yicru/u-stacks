{
  "name": "shadow",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "deploy": "dotenvx run -f .dev.vars.production -- bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "tsc -p tsconfig.check.json --noEmit && oxlint . && oxfmt --check .",
    "format": "oxlint --fix . && oxfmt .",
    "db:generate": "dotenvx run -f .dev.vars -- drizzle-kit generate",
    "db:migrate": "dotenvx run -f .dev.vars -- drizzle-kit push",
    "db:migrate:prod": "dotenvx run -f .dev.vars.production -- drizzle-kit push",
    "db:studio": "dotenvx run -f .dev.vars -- drizzle-kit studio",
    "generate:module": "scaffdog generate module"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@date-fns/tz": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@hono/zod-validator": "^0.7.6",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@libsql/client": "0.15.15",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.163.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.3",
    "input-otp": "^1.4.2",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@dotenvx/dotenvx": "^1.52.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.5.2",
    "@tanstack/router-plugin": "^1.163.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "scaffdog": "^4.1.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
